# Local mirror of the production stack. Copy to docker/.env.local.
# It uses the same pinned application and Payments revisions as production, but
# a different Compose project and volumes so it can never touch production data.
COMPOSE_PROJECT_NAME=lms-local
BASE_IMAGE=ghcr.io/frappe/lms:v2.54.2@sha256:a867b72db5ca58a86255197165fef4ac2535725862f6e6cb15276e73729e181f
PAYMENTS_REF=92a9cfbd739c54a8e4d3e84edb85eed0b64fb5b4
APP_IMAGE=lms-production
APP_IMAGE_TAG=local
MARIADB_IMAGE=mariadb:10.11.13

SITE_NAME=lms.localhost
PUBLIC_URL=http://localhost:8080
CADDY_SITE_ADDRESS=:80
HTTP_PORT=8080
HTTPS_PORT=8443
HEALTHCHECK_PORT=8080

MARIADB_ROOT_PASSWORD=123
ADMIN_PASSWORD=admin

BACKUPS_ENABLED=false
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
