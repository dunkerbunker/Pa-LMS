# Copy to docker/.env.production. Do not commit that file.
COMPOSE_PROJECT_NAME=lms-prod
BASE_IMAGE=ghcr.io/frappe/lms:v2.54.2@sha256:a867b72db5ca58a86255197165fef4ac2535725862f6e6cb15276e73729e181f
# Pinned to the last compatible Payments revision using Razorpay 1.x, matching
# this LMS app's declared dependency. Review and update both apps together.
PAYMENTS_REF=92a9cfbd739c54a8e4d3e84edb85eed0b64fb5b4
APP_IMAGE=lms-production
APP_IMAGE_TAG=local
MARIADB_IMAGE=mariadb:10.11.13

SITE_NAME=lms.example.com
PUBLIC_URL=https://lms.example.com
CADDY_SITE_ADDRESS=lms.example.com
HTTP_PORT=80
HTTPS_PORT=443
HEALTHCHECK_PORT=80

# Kept only to preserve the current credentials. Rotate before public launch.
MARIADB_ROOT_PASSWORD=123
ADMIN_PASSWORD=admin

# DigitalOcean Spaces integration is prepared but deliberately disabled.
BACKUPS_ENABLED=false
DO_SPACES_REGION=nyc3
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=
